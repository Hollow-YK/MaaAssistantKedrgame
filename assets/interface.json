{
    // 本文件主要定义了通用 UI 的行为和显示内容
    // 可参考文档和示例添加更多您需要的功能
    // 文档：https://maafw.xyz/docs/3.3-ProjectInterfaceV2
    // 示例：https://github.com/MaaXYZ/MaaFramework/blob/main/sample/interface.json
    "interface_version": 2,
    "name": "MaaAssistantKedrgame",
    "description": "$interface.description",
    "contact": "$interface.contact",
    "license": "[GNU Affero General Public License v3.0 (AGPL-3.0)](https://www.gnu.org/licenses/agpl-3.0.en.html)",
    "welcome": "首次使用！欢迎使用 MAA!",
    // 填写项目地址和版本号可实现自动更新功能
    "github": "https://github.com/Hollow-YK/MaaAssistantKedrgame",
    "version": "1.0.0",
    // Mirror酱为第三方分发服务，新项目默认关闭
    // 若有需要请联系 Mirror酱 开通，直接自行开启是无法使用的
    // "mirrorchyan_rid": "MaaXXX",
    // "mirrorchyan_multiplatform": true,
    "languages": {
        "zh_cn": "resource/locales/interface/zh_cn.json"
    },
    "controller": [
        {
            "name": "ADB",
            "label": "$controller.ADB.label",
            "type": "Adb",
            "display_short_side": 720 // 默认缩放分辨率的短边长度
        }
    ],
    "resource": [
        {
            "name": "官服",
            "path": [
                "./resource"
            ]
        },
        {
            "name": "B 服",
            "path": [
                "./resource"
                // "./resource_bilibili"
            ]
        },
        {
            "name": "其它",
            "path": [
                "./resource"
            ]
        }
    ],
    "agent": {
        "child_exec": "python",
        "child_args": [
            "-u",
            "./../agent/main.py"
        ]
    },
    "group": [
        {
            "name": "Daily",
            "label": "$group.Daily.label",
            "default_expand": true
        }
    ],
    "task": [],
    "import": [
        "resource/tasks/StartGame.json"
    ],
    "option": {},
    "title": "MAK v325.799 | 雪松小助手"
}
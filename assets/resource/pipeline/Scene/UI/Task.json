{
    "UI_Task_DailyTask": {
        "desc": "任务-每日任务(页面确认)",
        "recognition": "Or",
        "any_of": [
            "UI_Task_DailyTask_withredpoint",
            "UI_Task_DailyTask_withoutredpoint",
            "UI_Task_DailyTask_selected_withredpoint",
            "UI_Task_DailyTask_selected_withoutredpoint"
        ]
    },
    "UI_Task_DailyTask_selected": {

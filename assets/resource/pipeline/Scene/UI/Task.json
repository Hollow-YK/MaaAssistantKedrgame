        "desc": "任务-每日任务(无红点)",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": "UI/task/dailytask.png",
                // [398,108,136,42]
                "roi": [
                    1040,
                    640,
                    230,
                    70
                ]
            }
        }
    },

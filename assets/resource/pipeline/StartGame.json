{
    "StartGameMain": {
        "desc": "启动游戏入口",
        "next": [
            "StartGameApp"
        ]
    },
    "StartGameApp": {
        "desc": "启动游戏",
        "action": {
            "type": "StartApp",
            "param": {
                "package": "com.phxh.official.nld"
            }
        },
        "next": [
            "[JumpBack]StartGame_icon",
            "[JumpBack]GameResources_update_OCR",
            "[JumpBack]GameResources_update_wait",
            "[JumpBack]StartGame_wait",
            "StartGame_ClickStart"
        ]
    },
    "StartGame_icon": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": "StartGame/8.png"
            }
        }
    },
    "GameResources_update_OCR": {
        "desc": "游戏资源更新下载OCR",
        "recognition": "And",
        "all_of": [
            {
                "recognition": {
                    "type": "OCR",
                    "param": {
                        "expected": [
                            "资源更新"
                        ],
                        "roi": [
                            340,
                            245,
                            595,
                            160
                        ]
                    }
                }
            },
            {
                "recognition": {
                    "type": "OCR",
                    "param": {
                        "expected": [
                            "是否下载"
                        ],
                        "roi": [
                            340,
                            245,
                            595,
                            160
                        ]
                    }
                }
            }
        ],
        "next": [
            "GameResources_update_confirm"
        ]
    },
    "GameResources_update_confirm": {
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
                    "确定"
                ],
                "roi": [
                    425,
                    468,
                    190,
                    35
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            "[JumpBack]GameResources_update_wait",
            "StartGame_ClickStart"
        ]
    },
    "GameResources_update_wait": {
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
                    "正在下载更新包"
                ],
                "roi": [
                    454,
                    655,
                    390,
                    60
                ]
            }
        }
    },
    "StartGame_wait": {
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
                    "请求APPConfig",
                    "APPConfig",
                    "初始化游戏",
                    "服务器版本信息"
                ],
                "roi": [
                    454,
                    655,
                    390,
                    60
                ]
            }
        }
    },
    "StartGame_ClickStart": {
        "pre_wait_freezes": 500,
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
                    "点击任意处开始"
                ],
                "roi": [
                    450,
                    555,
                    390,
                    40
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            "[JumpBack]StartGame_ClickStart_again",
            "StartGame_Login",
            "[JumpBack]StartGame_Login_wait",
            "[JumpBack]Award_DailyAward_Click:Get",
            "StartGame_Scene_Check_Homepage"
        ]
    },
    "StartGame_ClickStart_again": {
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
                    "点击任意处开始"
                ],
                "roi": [
                    450,
                    555,
                    390,
                    40
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "post_delay": 1000
    },
    "StartGame_Login": {
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
                    "验证码登录"
                ],
                "roi": [
                    540,
                    140,
                    200,
                    45
                ]
            }
        },
        "focus": {
            "Node.Recognition.Succeeded": {
                "content": "请先手动验证码登录",
                "display": [
                    "log",
                    "modal"
                ]
            }
        }
    },
    "StartGame_Login_wait": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": "StartGame/Loading.png",
                "green_mask": true
            }
        }
    },
    "StartGame_Scene_Check_Homepage": {
        "recognition": "And",
        "all_of": [
            "Status_In_MainMenu"
        ],
        "focus": {
            "Node.Recognition.Succeeded": {
                "content": "登录成功",
                "display": [
                    "log",
                    "toast"
                ]
            }
        }
    }
}
